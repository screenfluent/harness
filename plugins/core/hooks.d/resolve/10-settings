#!/usr/bin/env bash
# 10-settings — apply provider/model from settings.conf (most-local wins)
set -euo pipefail

input="$(cat)"

provider="$(echo "${input}" | jq -r '.provider // ""')"
model="$(echo "${input}" | jq -r '.model // ""')"
provider_was_empty="${provider:+no}"
provider_was_empty="${provider_was_empty:-yes}"

IFS=':' read -ra sources <<< "${HARNESS_SOURCES}"

for (( i=${#sources[@]}-1; i>=0; i-- )); do
  [[ -f "${sources[i]}/settings.conf" ]] || continue
  v="$(sed -n 's/^provider=//p' "${sources[i]}/settings.conf")"
  [[ -n "${v}" && -z "${provider}" ]] && provider="${v}"
  if [[ "${provider_was_empty}" == "yes" ]]; then
    v="$(sed -n 's/^model=//p' "${sources[i]}/settings.conf")"
    [[ -n "${v}" && -z "${model}" ]] && model="${v}"
  fi
  break
done

echo "${input}" | jq --arg p "${provider}" --arg m "${model}" '.provider = $p | .model = $m'
