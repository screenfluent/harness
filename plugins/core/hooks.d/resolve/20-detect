#!/usr/bin/env bash
# 20-detect — auto-detect the first ready provider
set -euo pipefail

input="$(cat)"

provider="$(echo "${input}" | jq -r '.provider // ""')"
if [[ -n "${provider}" ]]; then echo "${input}"; exit 0; fi

IFS=':' read -ra sources <<< "${HARNESS_SOURCES}"

for src in "${sources[@]}"; do
  [[ -d "${src}/providers" ]] || continue
  for f in "${src}/providers"/*; do
    [[ -e "${f}" ]] || continue
    if [[ -x "${f}" && ! "${f}" == *.conf ]]; then
      if "${f}" --ready 2>/dev/null; then
        provider="$(basename "${f}")"
        break 2
      fi
    elif [[ "${f}" == *.conf ]]; then
      name="$(basename "${f}" .conf)"
      ae="$(grep '^auth_env=' "${f}" | head -1 | cut -d= -f2-)"
      if [[ -n "${ae}" && -n "${!ae:-}" ]]; then
        provider="${name}"; break 2
      fi
      cache="${HARNESS_HOME:-${HOME}/.harness}/.auth-cache.json"
      if [[ -f "${cache}" ]] && jq -e ".\"${name}\" | length > 0" "${cache}" &>/dev/null; then
        exp="$(jq -r ".\"${name}\"[0].expires_at // \"0\"" "${cache}")"
        if [[ "${exp}" == "0" ]] || [[ "$(date +%s)" -lt "${exp}" ]]; then
          provider="${name}"; break 2
        fi
      fi
    fi
  done
done

if [[ -z "${provider}" ]]; then
  jq -n '{error: "no ready provider found — set HARNESS_PROVIDER or run: hs auth set <provider>"}'
  exit 1
fi

echo "${input}" | jq --arg p "${provider}" '.provider = $p'
