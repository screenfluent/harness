#!/usr/bin/env bash
# 30-defaults — fill in default model from provider conf or --defaults
set -euo pipefail

input="$(cat)"

provider="$(echo "${input}" | jq -r '.provider // ""')"
model="$(echo "${input}" | jq -r '.model // ""')"

if [[ -z "${provider}" || -n "${model}" ]]; then echo "${input}"; exit 0; fi

IFS=':' read -ra sources <<< "${HARNESS_SOURCES}"

# Check for variant .conf first (most-local wins)
for (( i=${#sources[@]}-1; i>=0; i-- )); do
  [[ -f "${sources[i]}/providers/${provider}.conf" ]] || continue
  model="$(grep '^model=' "${sources[i]}/providers/${provider}.conf" | head -1 | cut -d= -f2-)"
  break
done

# Fall back to provider binary --defaults
if [[ -z "${model}" ]]; then
  provider_path=""
  for (( i=${#sources[@]}-1; i>=0; i-- )); do
    [[ -x "${sources[i]}/providers/${provider}" ]] && { provider_path="${sources[i]}/providers/${provider}"; break; }
  done
  if [[ -n "${provider_path}" ]]; then
    while IFS='=' read -r key val; do
      [[ "${key}" == "model" ]] && { model="${val}"; break; }
    done < <("${provider_path}" --defaults 2>/dev/null || true)
  fi
fi

echo "${input}" | jq --arg m "${model}" '.model = $m'
