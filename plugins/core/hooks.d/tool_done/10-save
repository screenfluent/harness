#!/usr/bin/env bash
# 10-save — save a tool result as a canonical message file.
# Receives JSON: {call_id, name, input, result, error}.
set -euo pipefail

data="$(cat)"
msg_dir="${HARNESS_SESSION}/messages"
[[ -d "${msg_dir}" ]] || exit 0

# Next sequence number
last="$(ls -1 "${msg_dir}/" 2>/dev/null | sort -n | tail -1)"
if [[ -z "${last}" ]]; then
  seq="0001"
else
  seq="$(printf '%04d' $(( 10#${last%%-*} + 1 )))"
fi

call_id="$(echo "${data}" | jq -r '.call_id')"
tool="$(echo "${data}" | jq -r '.name')"
error="$(echo "${data}" | jq -r '.error')"
result="$(echo "${data}" | jq -r '.result')"

cat > "${msg_dir}/${seq}-tool_result.md" <<EOF
---
role: tool_result
seq: ${seq}
timestamp: $(date -Iseconds)
call_id: ${call_id}
tool: ${tool}
error: ${error}
---
${result}
EOF

# Pass through
echo "${data}"
