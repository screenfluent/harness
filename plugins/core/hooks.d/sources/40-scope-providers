#!/usr/bin/env bash
# 40-scope-providers — filter source dirs by active provider
set -euo pipefail

input="$(cat)"

# No provider set → pass through unscoped (needed for auto-detection)
[[ -z "${HARNESS_PROVIDER:-}" ]] && { echo "${input}"; exit 0; }

# Resolve variant protocol (if HARNESS_PROVIDER is a .conf variant).
# Last match wins (local overrides global).
protocol=""
while IFS= read -r dir; do
  [[ -f "${dir}/providers/${HARNESS_PROVIDER}.conf" ]] || continue
  protocol="$(grep '^protocol=' "${dir}/providers/${HARNESS_PROVIDER}.conf" | head -1 | cut -d= -f2-)"
done < <(echo "${input}" | jq -r '.sources[]')

# Filter: skip provider-plugin dirs that don't match.
# A "provider plugin" is a dir whose providers/ subdir contains an executable
# or conf named after the dir itself (e.g. plugins/openai/providers/openai).
# Non-provider dirs (core, auth, ~/.harness) always pass through.
filtered=()
while IFS= read -r dir; do
  if [[ -d "${dir}/providers" ]]; then
    dir_base="$(basename "${dir}")"
    if [[ -x "${dir}/providers/${dir_base}" || -f "${dir}/providers/${dir_base}.conf" ]]; then
      # Provider-plugin dir — keep only if it matches provider or protocol
      [[ "${dir_base}" != "${HARNESS_PROVIDER}" && "${dir_base}" != "${protocol}" ]] && continue
    fi
  fi
  filtered+=("${dir}")
done < <(echo "${input}" | jq -r '.sources[]')

printf '%s\n' "${filtered[@]}" | jq -R . | jq -s '{sources: .}'
