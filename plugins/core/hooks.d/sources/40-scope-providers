#!/usr/bin/env bash
# 40-scope-providers — filter source dirs by active provider
set -euo pipefail

input="$(cat)"

# No provider set → pass through unscoped (needed for auto-detection)
[[ -z "${HARNESS_PROVIDER:-}" ]] && { echo "${input}"; exit 0; }

# Filter: skip dirs that have a providers/ subdir but wrong basename
filtered=()
while IFS= read -r dir; do
  if [[ -d "${dir}/providers" && "$(basename "${dir}")" != "${HARNESS_PROVIDER}" ]]; then
    continue
  fi
  filtered+=("${dir}")
done < <(echo "${input}" | jq -r '.sources[]')

printf '%s\n' "${filtered[@]}" | jq -R . | jq -s '{sources: .}'
