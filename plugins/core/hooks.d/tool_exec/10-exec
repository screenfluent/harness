#!/usr/bin/env bash
# 10-exec — pop and execute the first tool call from the queue.
# Receives context JSON on stdin: {tool_calls: [{id, name, input}, ...]}.
# Returns: {call_id, name, input, result, error, tool_calls: [...remaining], next_state: "tool_done"}.
set -euo pipefail

data="$(cat)"
call_id="$(echo "${data}" | jq -r '.tool_calls[0].id')"
tool_name="$(echo "${data}" | jq -r '.tool_calls[0].name')"
input="$(echo "${data}" | jq -c '.tool_calls[0].input')"
remaining="$(echo "${data}" | jq -c '.tool_calls[1:]')"

# Read HARNESS_CWD from session config
if [[ -z "${HARNESS_CWD:-}" && -f "${HARNESS_SESSION}/session.conf" ]]; then
  cwd="$(sed -n 's/^cwd=//p' "${HARNESS_SESSION}/session.conf")"
  [[ -n "${cwd}" ]] && export HARNESS_CWD="${cwd}"
fi

# Discover tool binary from HARNESS_SOURCES (highest priority = last in list)
tool_bin=""
IFS=':' read -ra sources <<< "${HARNESS_SOURCES}"
for (( i=${#sources[@]}-1; i>=0; i-- )); do
  candidate="${sources[i]}/tools/${tool_name}"
  if [[ -x "${candidate}" ]]; then
    tool_bin="${candidate}"
    break
  fi
done

result=""
error=false

# Check for pre-dispatched result from streaming parallel execution
_precomputed="${HARNESS_SESSION}/.tool_dispatch/${call_id}.json"
if [[ -f "${_precomputed}" ]]; then
  result="$(jq -r '.result' "${_precomputed}")"
  [[ "$(jq -r '.error' "${_precomputed}")" == "true" ]] && error=true
  echo "[harness] tool pre-dispatched: ${tool_name}" >> "${HARNESS_LOG}"
elif [[ -z "${tool_bin}" ]]; then
  result="error: tool '${tool_name}' not found"
  error=true
else
  workdir="${HARNESS_CWD:-${PWD}}"
  if result="$(cd "${workdir}" && echo "${input}" | "${tool_bin}" --exec 2>&1)"; then
    error=false
  else
    error=true
  fi
fi

# Display tool execution
{
  # Tool header: dim color + name
  printf '\033[2m  ┌ \033[0m\033[1;35m%s\033[0m' "${tool_name}"

  # Show key params inline
  if [[ "${tool_name}" == "bash" ]]; then
    _cmd="$(echo "${input}" | jq -r '.command // empty')"
    # Truncate long commands
    if (( ${#_cmd} > 80 )); then
      printf ' \033[2m%s…\033[0m' "${_cmd:0:80}"
    else
      printf ' \033[2m%s\033[0m' "${_cmd}"
    fi
  elif [[ "${tool_name}" == "read_file" ]]; then
    _path="$(echo "${input}" | jq -r '.path // empty')"
    printf ' \033[2m%s\033[0m' "${_path}"
  elif [[ "${tool_name}" == "write_file" ]]; then
    _path="$(echo "${input}" | jq -r '.path // empty')"
    printf ' \033[2m%s\033[0m' "${_path}"
  elif [[ "${tool_name}" == "str_replace" ]]; then
    _path="$(echo "${input}" | jq -r '.path // empty')"
    printf ' \033[2m%s\033[0m' "${_path}"
  elif [[ "${tool_name}" == "list_dir" ]]; then
    _path="$(echo "${input}" | jq -r '.path // empty')"
    printf ' \033[2m%s\033[0m' "${_path}"
  fi
  printf '\n'

  # Result (dim, indented, truncated)
  if [[ -n "${result}" ]]; then
    total_lines="$(printf '%s' "${result}" | wc -l)"
    total_lines=$(( total_lines + 0 ))  # trim whitespace
    if (( total_lines > 20 )); then
      printf '%s\n' "${result}" | head -10 | sed 's/^/\x1b[2m  │ \x1b[0m/'
      printf '\033[2m  │ … %d more lines\033[0m\n' $(( total_lines - 10 ))
    else
      printf '%s\n' "${result}" | sed 's/^/\x1b[2m  │ \x1b[0m/'
    fi
  fi

  # Status
  if [[ "${error}" == "true" ]]; then
    printf '\033[2m  └ \033[31merror\033[0m\n'
  else
    printf '\033[2m  └ done\033[0m\n'
  fi
} >> "${HARNESS_LOG}" 2>/dev/null || true

# Return result JSON with remaining tool calls
jq -n \
  --arg call_id "${call_id}" \
  --arg name "${tool_name}" \
  --argjson input "${input}" \
  --arg result "${result}" \
  --argjson error "${error}" \
  --argjson tool_calls "${remaining}" \
  '{call_id: $call_id, name: $name, input: $input, result: $result, error: $error, tool_calls: $tool_calls, next_state: "tool_done"}'
