#!/usr/bin/env bash
# str_replace — tool plugin: replace unique strings in a file.
set -euo pipefail

case "${1:-}" in
  --schema)
    cat <<'JSON'
{
  "name": "str_replace",
  "description": "Replace unique strings in a file. Supports single replacement (old_str/new_str) or multiple replacements (edits array). Each old_str must appear exactly once in the file. All edits are validated against the original file before any are applied.",
  "input_schema": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "Path to the file"
      },
      "old_str": {
        "type": "string",
        "description": "Exact string to find (must be unique). Use this for single edits."
      },
      "new_str": {
        "type": "string",
        "description": "Replacement string (empty string to delete). Use with old_str."
      },
      "edits": {
        "type": "array",
        "description": "Multiple replacements. Each edit has old_str and new_str. All validated before applying. Use this instead of old_str/new_str for multiple changes.",
        "items": {
          "type": "object",
          "properties": {
            "old_str": { "type": "string", "description": "Exact string to find (must be unique)" },
            "new_str": { "type": "string", "description": "Replacement string" }
          },
          "required": ["old_str", "new_str"]
        }
      }
    },
    "required": ["path"]
  }
}
JSON
    ;;
  --describe)
    echo "Replace a unique string in a file"
    ;;
  --exec)
    input="$(cat)"
    path="$(echo "${input}" | jq -r '.path')"

    if [[ "${path}" != /* ]]; then
      path="${HARNESS_CWD:-${PWD}}/${path}"
    fi

    if [[ ! -f "${path}" ]]; then
      echo "error: file not found: ${path}"
      exit 1
    fi

    # Normalize: single old_str/new_str → edits array
    has_edits="$(echo "${input}" | jq 'has("edits") and (.edits | length > 0)')"
    if [[ "${has_edits}" == "true" ]]; then
      edits_json="$(echo "${input}" | jq -c '.edits')"
    else
      edits_json="$(echo "${input}" | jq -c '[{old_str: .old_str, new_str: .new_str}]')"
    fi

    # Validate + apply all edits in python
    REPLACE_PATH="${path}" EDITS_JSON="${edits_json}" python3 -c "
import os, json, sys

path = os.environ['REPLACE_PATH']
edits = json.loads(os.environ['EDITS_JSON'])

with open(path) as f:
    content = f.read()

# Validate all edits against original content first
errors = []
for i, edit in enumerate(edits):
    old = edit['old_str']
    count = content.count(old)
    if count == 0:
        errors.append(f'edit {i+1}: old_str not found')
    elif count > 1:
        errors.append(f'edit {i+1}: old_str appears {count} times (must be unique)')

if errors:
    print('\\n'.join(errors))
    sys.exit(1)

# Apply edits sequentially
for edit in edits:
    content = content.replace(edit['old_str'], edit['new_str'], 1)

with open(path, 'w') as f:
    f.write(content)

n = len(edits)
print(f'{n} edit{\"s\" if n > 1 else \"\"} applied to {path}')
" || exit 1
    ;;
  *)
    echo "usage: str_replace --schema | --describe | --exec" >&2
    exit 1
    ;;
esac
