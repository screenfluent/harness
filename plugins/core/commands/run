#!/usr/bin/env bash
# harness run — one-shot: create session, run to completion
set -euo pipefail

case "${1:-}" in
  --describe) echo "one-shot: create session, run to completion"; exit 0 ;;
esac

source "${HARNESS_ROOT}/bin/harness"

message=""
if (( $# > 0 )); then
  message="$*"
elif [[ ! -t 0 ]]; then
  message="$(cat)"
else
  _die "usage: harness run <message>"
fi

session_dir="$(session_new)"
_log "session: ${session_dir}"
echo "session: $(basename "${session_dir}")" >&2

save_user_message "${session_dir}" "${message}"
agent_loop "${session_dir}"
