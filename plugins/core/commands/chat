#!/usr/bin/env bash
# harness chat — interactive REPL (new or resume session)
set -euo pipefail

case "${1:-}" in
  --describe) echo "interactive REPL (new or resume session)"; exit 0 ;;
esac

source "${HARNESS_ROOT}/bin/harness"

session_dir=""
if [[ -n "${1:-}" ]]; then
  session_dir="${HARNESS_SESSIONS}/$1"
  [[ -d "${session_dir}" ]] || _die "session '$1' not found"
else
  session_dir="$(session_new)"
  echo "session: $(basename "${session_dir}")" >&2
fi

while true; do
  printf '\n\033[1;36mYou:\033[0m '
  IFS= read -r input || break
  [[ -z "${input}" ]] && continue
  [[ "${input}" == "/quit" || "${input}" == "/exit" ]] && break

  if [[ "${input}" == "/session" ]]; then
    echo "${session_dir}"
    continue
  fi

  save_user_message "${session_dir}" "${input}"
  printf '\033[1;33mAgent:\033[0m '
  agent_loop "${session_dir}"
  echo
done
